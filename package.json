    },
    "./options": {
      "types": "./dist/runtime/options/index.d.ts",
      "import": "./dist/runtime/options/index.js"
    },
    "./ofetch-adapter": {
      "types": "./dist/runtime/adapters/ofetch.d.ts",
      "import": "./dist/runtime/adapters/ofetch.js"
    },
    "./validators": {
      "types": "./dist/runtime/zod/validators.d.ts",
      "import": "./dist/runtime/zod/validators.js"
    },
    "./objectId": {
      "types": "./dist/runtime/zod/objectId.d.ts",
      "import": "./dist/runtime/zod/objectId.js"
    },
    "./query": {
      "types": "./dist/runtime/zod/query.d.ts",
