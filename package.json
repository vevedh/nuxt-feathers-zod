  "bin": {
    "nuxt-feathers-zod": "./bin/nuxt-feathers-zod",
    "nfz": "./bin/nfz"
  },
  "files": [
    "dist",
    "bin",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "prepack": "bun run sync:release-meta && bun run sanity:release-files && bun run sanity:internal-imports && bun run build && bun run sanity:package-exports",
    "dev": "bun run playground:dev",
    "playground:ensure-link": "node scripts/ensure-playground-self-link.mjs",
    "playground:dev": "bun run playground:ensure-link && nuxi dev playground",
    "build": "bun run module:prepare && bun run module:build && bun run sanity:file-service-template && bun run cli:build && bun run sanity:cli-dist-meta && bun run sanity:package-exports",
    "playground:build": "bun run playground:ensure-link && nuxi build playground",
    "module:prepare": "nuxt-module-build prepare",
    "module:build": "nuxt-module-build build",
    "prepare": "bun run sync:release-meta && bun run sanity:internal-imports && bun run module:prepare && bun run module:build && bun run sanity:file-service-template && bun run cli:build && bun run sanity:cli-dist-meta && bun run sanity:package-exports && bun run playground:ensure-link",
    "typecheck": "bunx tsc -p tsconfig.typecheck.json --noEmit",
    "test": "vitest run -c vitest.config.mts",
    "test:e2e": "vitest run -c vitest.config.mts test/e2e/**/*.spec.ts",
    "smoke:tarball": "node scripts/smoke-tarball-install.mjs",
    "release:check:full": "bun run release:check && bun run test:e2e && bun run smoke:tarball",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "cli:smoke": "bun scripts/cli-smoke.ts",
    "publish:npm": "bun run prepack && bun publish --access public",
    "release:check": "bun run sync:release-meta && bun run lint && bun run sanity:templates && bun run sanity:file-service-template && bun run sanity:syntax && bun run sanity:internal-imports && bun run sanity:release-meta && bun run sanity:release-files && bun run typecheck && bun run prepare && bun run build && bun run docs:build && bun run cli:smoke && bun pm pack --dry-run && bun run sanity:package-exports",
    "release": "bunx release-it",
    "release:patch": "bunx release-it patch",
    "release:minor": "bunx release-it minor",
    "release:major": "bunx release-it major",
    "docs:dev": "bun run docs:check-frontmatter && cd docs && bun install && bunx vitepress dev . --host",
    "docs:build": "bun run docs:check-frontmatter && cd docs && bun install && bunx vitepress build .",
    "docs:preview": "cd docs && bun install && bunx vitepress preview .",
    "sync:actions": "bunx nuxt-feathers-zod add service actions --custom --methods find --customMethods run --auth --docs --force",
    "sync:golden": "bun run sync:actions",
    "sanity:templates": "node scripts/template-safety-check.mjs",
    "sanity:syntax": "node scripts/syntax-check-ts.cjs",
    "sanity:internal-imports": "node scripts/check-internal-self-imports.mjs",
    "cli:build": "node scripts/build-cli.mjs",
    "sanity:release-meta": "node scripts/check-release-metadata.mjs",
    "sync:release-meta": "node scripts/sync-release-metadata.mjs",
    "sanity:release-files": "node scripts/check-release-files.mjs",
    "clean:repo": "node scripts/cleanup-safe.mjs",
    "sanity:file-service-template": "node scripts/check-file-service-template.mjs",
    "repo:doctor": "bun run clean:repo && bun run sanity:release-files && bun run sanity:internal-imports && bun run sanity:file-service-template",
    "sanity:cli-dist-meta": "node scripts/check-cli-dist-meta.mjs",
    "repo:bootstrap": "bun install && bun run repo:doctor",
    "docs:check-frontmatter": "node scripts/check-docs-frontmatter.mjs",
    "sanity:package-exports": "node scripts/check-package-exports.mjs",
    "deps:check": "taze",
    "deps:check:recursive": "taze -r",
    "deps:update:patch": "taze patch -w",
    "deps:update:minor": "taze minor -w",
    "deps:update:latest": "taze latest -w",
    "deps:update:major": "taze major -w",
    "deps:update:safe": "bun run deps:update:patch && bun install && bun run verify:all",
    "deps:update:minor:safe": "bun run deps:update:minor && bun install && bun run verify:all",
    "deps:update:full-smoke": "bun run build && bun run cli:full-smoke && bun run verify:sanity",
    "verify:install": "bun install --frozen-lockfile",
    "verify:build": "bun run build",
    "verify:typecheck": "bun run typecheck",
    "verify:test": "bun test",
    "verify:cli": "bun run cli:build && bun run cli:smoke && bun run cli:full-smoke",
    "verify:sanity": "bun run sanity:release-meta && bun run sanity:package-exports && bun run sanity:cli-dist-meta && bun run docs:check-frontmatter && bun run sanity:client-runtime-esm-interop",
    "verify:all": "bun run verify:build && bun run verify:typecheck && bun run verify:test && bun run verify:cli && bun run verify:sanity",
    "verify:full": "bun run verify:install && bun run verify:all",
    "cli:full-smoke": "bun scripts/cli-full-smoke.ts",
    "sanity:client-runtime-esm-interop": "node scripts/check-client-runtime-esm-interop.mjs"
  },
