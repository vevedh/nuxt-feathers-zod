{
  "name": "nuxt-feathers-zod",
  "type": "module",
  "version": "6.3.9",
  "packageManager": "bun@1.3.6",
  "description": "Feathers API integration for Nuxt",
  "author": "Herve de CHAVIGNY",
  "license": "MIT",
  "repository": {
    "type": "github",
    "url": "git+ssh://git@github.com/vevedh/nuxt-feathers-zod.git"
  },
  "exports": {
    ".": {
      "types": "./dist/types.d.mts",
      "import": "./dist/module.mjs"
    },
    "./server": {
      "types": "./dist/runtime/templates/server/server.d.ts",
      "import": "./dist/runtime/templates/server/server.js"
    },
    "./client": {
      "types": "./dist/runtime/templates/client/client.d.ts",
      "import": "./dist/runtime/templates/client/client.js"
    },
    "./auth-utils": {
      "types": "./dist/runtime/utils/auth.d.ts",
      "import": "./dist/runtime/utils/auth.js"
    },
    "./config-utils": {
      "types": "./dist/runtime/utils/config.d.ts",
      "import": "./dist/runtime/utils/config.js"
    },
    "./options": {
      "types": "./dist/runtime/options/index.d.ts",
      "import": "./dist/runtime/options/index.js"
    },
    "./ofetch-adapter": {
      "types": "./dist/runtime/adapters/ofetch.d.ts",
      "import": "./dist/runtime/adapters/ofetch.js"
    },
    "./validators": {
      "types": "./dist/runtime/zod/validators.d.ts",
      "import": "./dist/runtime/zod/validators.js"
    },
    "./objectId": {
      "types": "./dist/runtime/zod/objectId.d.ts",
      "import": "./dist/runtime/zod/objectId.js"
    },
    "./query": {
      "types": "./dist/runtime/zod/query.d.ts",
      "import": "./dist/runtime/zod/query.js"
    },
    "./format": {
      "types": "./dist/runtime/zod/format.d.ts",
      "import": "./dist/runtime/zod/format.js"
    },
    "./zod": {
      "types": "./dist/runtime/zod/index.d.ts",
      "import": "./dist/runtime/zod/index.js"
    },
    "./server/modules/express/*": {
      "types": "./dist/runtime/server/modules/express/*.d.ts",
      "import": "./dist/runtime/server/modules/express/*.js"
    },
    "./server/modules/koa/*": {
      "types": "./dist/runtime/server/modules/koa/*.d.ts",
      "import": "./dist/runtime/server/modules/koa/*.js"
    }
  },
  "main": "./dist/module.mjs",
  "typesVersions": {
    "*": {
      ".": [
        "./dist/types.d.mts"
      ],
      "server": [
        "./dist/runtime/templates/server/server.d.ts"
      ],
      "client": [
        "./dist/runtime/templates/client/client.d.ts"
      ],
      "auth-utils": [
        "./dist/runtime/utils/auth.d.ts"
      ],
      "config-utils": [
        "./dist/runtime/utils/config.d.ts"
      ],
      "options": [
        "./dist/runtime/options/index.d.ts"
      ],
      "ofetch-adapter": [
        "./dist/runtime/adapters/ofetch.d.ts"
      ],
      "validators": [
        "./dist/runtime/zod/validators.d.ts"
      ],
      "objectId": [
        "./dist/runtime/zod/objectId.d.ts"
      ],
      "query": [
        "./dist/runtime/zod/query.d.ts"
      ],
      "format": [
        "./dist/runtime/zod/format.d.ts"
      ],
      "zod": [
        "./dist/runtime/zod/index.d.ts"
      ],
      "server/modules/express/*": [
        "./dist/runtime/server/modules/express/*.d.ts"
      ],
      "server/modules/koa/*": [
        "./dist/runtime/server/modules/koa/*.d.ts"
      ]
    }
  },
  "bin": {
    "nuxt-feathers-zod": "./dist/cli/index.mjs",
    "nfz": "./dist/cli/index.mjs"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "prepack": "bun run build",
    "dev": "bun run playground:dev",
    "playground:dev": "nuxi dev playground",
    "build": "bun run module:prepare && bun run module:build && bun run cli:build",
    "playground:build": "nuxi build playground",
    "module:prepare": "nuxt-module-build prepare",
    "module:build": "nuxt-module-build build",
    "prepare": "bun run module:prepare && bun run module:build && bun run cli:build",
    "typecheck": "bunx tsc -p tsconfig.typecheck.json --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "cli:smoke": "bun scripts/cli-smoke.ts",
    "publish:npm": "bun run prepack && bun publish --access public",
    "release:check": "bun run lint && bun run sanity:templates && bun run sanity:syntax && bun run typecheck && bun run prepare && bun run build && bun run docs:build && bun run cli:smoke && bun pm pack --dry-run",
    "release": "bunx release-it",
    "release:patch": "bunx release-it patch",
    "release:minor": "bunx release-it minor",
    "release:major": "bunx release-it major",
    "docs:dev": "cd docs && bun install && bunx vitepress dev . --host",
    "docs:build": "cd docs && bun install && bunx vitepress build .",
    "docs:preview": "cd docs && bun install && bunx vitepress preview .",
    "sync:actions": "bunx nuxt-feathers-zod add service actions --custom --methods find --customMethods run --auth --docs --force",
    "sync:golden": "bun run sync:actions",
    "sanity:templates": "node scripts/template-safety-check.mjs",
    "sanity:syntax": "node scripts/syntax-check-ts.cjs",
    "cli:build": "mkdir -p dist/cli && bun build src/cli/bin.ts --outfile dist/cli/index.mjs --target=node --format=esm"
  },
  "peerDependencies": {
    "nuxt": "^4.0.0"
  },
  "dependencies": {
    "@feathersjs/adapter-commons": "latest",
    "@feathersjs/authentication": "5.0.37",
    "@feathersjs/authentication-client": "latest",
    "@feathersjs/authentication-local": "latest",
    "@feathersjs/authentication-oauth": "^5.0.40",
    "@feathersjs/configuration": "latest",
    "@feathersjs/errors": "^5.0.37",
    "@feathersjs/feathers": "latest",
    "@feathersjs/generators": "latest",
    "@feathersjs/koa": "^5.0.37",
    "@feathersjs/memory": "latest",
    "@feathersjs/mongodb": "latest",
    "@feathersjs/rest-client": "latest",
    "@feathersjs/schema": "^5.0.37",
    "@feathersjs/socketio": "latest",
    "@feathersjs/socketio-client": "latest",
    "@gabortorma/feathers-nitro-adapter": "latest",
    "@koa/cors": "latest",
    "@nuxt/kit": "latest",
    "ajv-formats": "^3.0.1",
    "change-case": "latest",
    "citty": "^0.2.1",
    "compression": "^1.7.4",
    "consola": "latest",
    "cors": "^2.8.5",
    "defu": "latest",
    "feathers-pinia": "^4.5.4",
    "feathers-mongodb-management-ts": "2.1.0",
    "feathers-swagger": "^3.0.0",
    "helmet": "^7.1.0",
    "jose": "^5.10.0",
    "keycloak-js": "^24.0.5",
    "koa-compress": "latest",
    "koa-helmet": "latest",
    "koa-static": "latest",
    "mongodb": "^6.21.0",
    "pinia": "latest",
    "socket.io": "latest",
    "socket.io-client": "latest",
    "swagger-ui-dist": "^5.31.0",
    "unimport": "^3.14.6",
    "zod": "^3.25.76",
    "@nuxt/devtools-kit": "^3.2.3"
  },
  "devDependencies": {
    "@antfu/ni": "latest",
    "@gabortorma/antfu-eslint-config": "^1.7.4",
    "@gabortorma/mwm": "latest",
    "@gabortorma/nuxt-eslint-layer": "latest",
    "@nuxt/devtools": "latest",
    "@nuxt/module-builder": "latest",
    "@nuxt/schema": "latest",
    "@nuxt/test-utils": "latest",
    "@pinia/nuxt": "^0.11.0",
    "@playwright/test": "latest",
    "@types/node": "latest",
    "dotenv": "^16.4.5",
    "dotenv-cli": "latest",
    "eslint": "^9.39.2",
    "nuxt": "^4.3.0",
    "release-it": "latest",
    "typescript": "latest",
    "vitest": "latest",
    "vitest-mongodb": "latest",
    "vue": "latest",
    "vue-router": "latest"
  }
}
