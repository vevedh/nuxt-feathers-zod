      "import": "./dist/runtime/zod/index.js"
    },
    "./server/modules/express/*": {
      "types": "./dist/runtime/server/modules/express/*.d.ts",
      "import": "./dist/runtime/server/modules/express/*.js"
    },
    "./server/modules/koa/*": {
      "types": "./dist/runtime/server/modules/koa/*.d.ts",
      "import": "./dist/runtime/server/modules/koa/*.js"
    },
    "./auth-runtime": {
      "types": "./dist/runtime/composables/useAuthRuntime.d.ts",
      "import": "./dist/runtime/composables/useAuthRuntime.js"
    },
    "./auth-bound-fetch": {
      "types": "./dist/runtime/composables/useAuthBoundFetch.d.ts",
      "import": "./dist/runtime/composables/useAuthBoundFetch.js"
    },
    "./protected-tool": {
      "types": "./dist/runtime/composables/useProtectedTool.d.ts",
      "import": "./dist/runtime/composables/useProtectedTool.js"
    },
    "./mongo-management-client": {
      "types": "./dist/runtime/composables/useMongoManagementClient.d.ts",
      "import": "./dist/runtime/composables/useMongoManagementClient.js"
    },
    "./keycloak-bridge": {
      "types": "./dist/runtime/composables/useKeycloakBridge.d.ts",
      "import": "./dist/runtime/composables/useKeycloakBridge.js"
    },
    "./protected-page": {
      "types": "./dist/runtime/composables/useProtectedPage.d.ts",
      "import": "./dist/runtime/composables/useProtectedPage.js"
    },
    "./auth-trace": {
      "types": "./dist/runtime/composables/useAuthTrace.d.ts",
      "import": "./dist/runtime/composables/useAuthTrace.js"
    },
    "./admin-client": {
      "types": "./dist/runtime/composables/useNfzAdminClient.d.ts",
      "import": "./dist/runtime/composables/useNfzAdminClient.js"
    },
    "./builder-client": {
      "types": "./dist/runtime/composables/useBuilderClient.d.ts",
      "import": "./dist/runtime/composables/useBuilderClient.js"
    }
  },
  "main": "./dist/module.mjs",
  "typesVersions": {
    "*": {
      ".": [
        "./dist/types.d.mts"
      ],
      "server": [
        "./dist/runtime/server.d.ts"
      ],
      "server-bootstrap": [
        "./dist/runtime/server/bootstrap.d.ts"
      ],
      "server-app-utils": [
        "./dist/runtime/server/app-utils.d.ts"
      ],
      "server-mongodb": [
        "./dist/runtime/server/mongodb.d.ts"
      ],
      "server-keycloak": [
        "./dist/runtime/server/keycloak.d.ts"
      ],
      "client": [
        "./dist/runtime/client.d.ts"
      ],
      "client-runtime": [
        "./dist/runtime/client/defineNfzClientPlugin.d.ts"
      ],
      "auth-utils": [
        "./dist/runtime/utils/auth.d.ts"
      ],
      "config-utils": [
        "./dist/runtime/utils/config.d.ts"
      ],
      "options": [
        "./dist/runtime/options/index.d.ts"
      ],
      "ofetch-adapter": [
        "./dist/runtime/adapters/ofetch.d.ts"
      ],
      "validators": [
        "./dist/runtime/zod/validators.d.ts"
      ],
      "objectId": [
        "./dist/runtime/zod/objectId.d.ts"
      ],
      "query": [
        "./dist/runtime/zod/query.d.ts"
      ],
      "format": [
        "./dist/runtime/zod/format.d.ts"
      ],
      "zod": [
        "./dist/runtime/zod/index.d.ts"
      ],
      "server/modules/express/*": [
        "./dist/runtime/server/modules/express/*.d.ts"
      ],
      "server/modules/koa/*": [
        "./dist/runtime/server/modules/koa/*.d.ts"
      ],
      "auth-runtime": [
        "./dist/runtime/composables/useAuthRuntime.d.ts"
      ],
      "auth-bound-fetch": [
        "./dist/runtime/composables/useAuthBoundFetch.d.ts"
      ],
      "protected-tool": [
        "./dist/runtime/composables/useProtectedTool.d.ts"
      ],
      "mongo-management-client": [
        "./dist/runtime/composables/useMongoManagementClient.d.ts"
      ],
      "keycloak-bridge": [
        "./dist/runtime/composables/useKeycloakBridge.d.ts"
