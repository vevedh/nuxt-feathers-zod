{
  "name": "nuxt-feathers-zod",
  "type": "module",
  "version": "6.5.26",
  "packageManager": "bun@1.3.6",
  "description": "Nuxt module for FeathersJS v5 with embedded or remote mode, typed services, auth helpers and CLI-first generation.",
  "author": "Herve de CHAVIGNY",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/vevedh/nuxt-feathers-zod.git"
  },
  "exports": {
    ".": {
      "types": "./dist/types.d.mts",
      "import": "./dist/module.mjs"
    },
    "./server": {
      "types": "./dist/runtime/server.d.ts",
      "import": "./dist/runtime/server.js"
    },
    "./server-bootstrap": {
      "types": "./dist/runtime/server/bootstrap.d.ts",
      "import": "./dist/runtime/server/bootstrap.js"
    },
