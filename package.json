{
  "name": "nuxt-feathers-zod",
  "type": "module",
  "version": "6.3.4",
  "packageManager": "bun@1.3.6",
  "description": "Feathers API integration for Nuxt",
  "author": "Herve de CHAVIGNY",
  "license": "MIT",
  "repository": {
    "type": "github",
    "url": "git+ssh://git@github.com/vevedh/nuxt-feathers-zod.git"
  },
  "exports": {
    ".": {
      "types": "./dist/types.d.mts",
      "import": "./dist/module.mjs"
    },
    "./options": "./dist/runtime/options/index.js",
    "./ofetch-adapter": "./dist/runtime/adapters/ofetch.js",
    "./validators": "./dist/runtime/zod/validators.js",
    "./objectId": "./dist/runtime/zod/objectId.js",
    "./query": "./dist/runtime/zod/query.js",
    "./format": "./dist/runtime/zod/format.js",
    "./zod": "./dist/runtime/zod/index.js"
  },
  "main": "./dist/module.mjs",
  "typesVersions": {
    "*": {
      ".": [
        "./dist/types.d.mts"
      ],
      "options": [
        "./dist/runtime/options/index.d.mts"
      ],
      "ofetch-adapter": [
        "./dist/runtime/adapters/ofetch.d.mts"
      ]
    }
  },
  "bin": {
    "nuxt-feathers-zod": "bin/nuxt-feathers-zod"
  },
  "files": [
    "bin",
    "dist",
    "src/cli",
    "src/runtime/server/modules"
  ],
  "scripts": {
    "prepack": "nuxt-module-build build",
    "dev": "bun run playground:dev",
    "playground:dev": "nuxi dev playground",
    "build": "bun run playground:build",
    "playground:build": "nuxi build playground",
    "module:prepare": "nuxt-module-build prepare",
    "module:build": "nuxt-module-build build",
    "prepare": "bun run module:prepare && bun run module:build",
    "typecheck": "bunx tsc -p tsconfig.typecheck.json --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "cli:smoke": "bun scripts/cli-smoke.ts",
    "publish:npm": "bun run prepack && bun publish --access public",
    "release:check": "bun run lint && bun run sanity:templates && bun run sanity:syntax && bun run typecheck && bun run prepare && bun run build:ci && bun run docs:build && bun run cli:smoke && bun pm pack --dry-run",
    "release": "bunx release-it",
    "release:patch": "bunx release-it patch",
    "release:minor": "bunx release-it minor",
    "release:major": "bunx release-it major",
    "docs:dev": "cd docs && bun install && bunx vitepress dev . --host",
    "docs:build": "cd docs && bun install && bunx vitepress build .",
    "docs:preview": "cd docs && bun install && bunx vitepress preview .",
    "sync:actions": "bunx nuxt-feathers-zod add service actions --custom --methods find --customMethods run --auth --docs --force",
    "sync:golden": "bun run sync:actions",
    "sanity:templates": "node scripts/template-safety-check.mjs",
    "sanity:syntax": "node scripts/syntax-check-ts.cjs",
    "build:ci": "node scripts/build-ci.mjs"
  },
  "peerDependencies": {
    "nuxt": "^4.0.0"
  },
  "dependencies": {
    "@feathersjs/adapter-commons": "latest",
    "@feathersjs/authentication": "5.0.37",
    "@feathersjs/authentication-client": "latest",
    "@feathersjs/authentication-local": "latest",
    "@feathersjs/authentication-oauth": "^5.0.40",
    "@feathersjs/configuration": "latest",
    "@feathersjs/errors": "^5.0.37",
    "@feathersjs/feathers": "latest",
    "@feathersjs/generators": "latest",
    "@feathersjs/koa": "^5.0.37",
    "@feathersjs/memory": "latest",
    "@feathersjs/mongodb": "latest",
    "@feathersjs/rest-client": "latest",
    "@feathersjs/schema": "^5.0.37",
    "@feathersjs/socketio": "latest",
    "@feathersjs/socketio-client": "latest",
    "@gabortorma/feathers-nitro-adapter": "latest",
    "@koa/cors": "latest",
    "@nuxt/kit": "latest",
    "ajv-formats": "^3.0.1",
    "change-case": "latest",
    "citty": "^0.2.1",
    "compression": "^1.7.4",
    "consola": "latest",
    "cors": "^2.8.5",
    "defu": "latest",
    "feathers-pinia": "^4.5.4",
    "feathers-mongodb-management-ts": "2.1.0",
    "feathers-swagger": "^3.0.0",
    "helmet": "^7.1.0",
    "jose": "^5.10.0",
    "keycloak-js": "^24.0.5",
    "koa-compress": "latest",
    "koa-helmet": "latest",
    "koa-static": "latest",
    "mongodb": "^6.21.0",
    "pinia": "latest",
    "socket.io": "latest",
    "socket.io-client": "latest",
    "swagger-ui-dist": "^5.31.0",
    "unimport": "^3.14.6",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@antfu/ni": "latest",
    "@gabortorma/antfu-eslint-config": "^1.7.4",
    "@gabortorma/mwm": "latest",
    "@gabortorma/nuxt-eslint-layer": "latest",
    "@nuxt/devtools": "latest",
    "@nuxt/module-builder": "latest",
    "@nuxt/schema": "latest",
    "@nuxt/test-utils": "latest",
    "@pinia/nuxt": "^0.11.0",
    "@playwright/test": "latest",
    "@types/node": "latest",
    "dotenv": "^16.4.5",
    "dotenv-cli": "latest",
    "eslint": "^9.39.2",
    "nuxt": "^4.3.0",
    "release-it": "latest",
    "typescript": "latest",
    "vitest": "latest",
    "vitest-mongodb": "latest",
    "vue": "latest",
    "vue-router": "latest"
  }
}
