{
  "name": "nfz-quasar-unocss-pinia-starter",
  "type": "module",
  "version": "0.1.3",
  "private": true,
  "packageManager": "bun@1.3.6",
  "scripts": {
    "db:up": "docker compose up -d mongodb",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f mongodb",
    "dev": "nuxt dev",
    "dev:db": "bun run db:up && bun dev",
    "build": "nuxt build",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "prepare": "nuxt prepare",
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "dependencies": {
    "@feathersjs/authentication": "5.0.37",
    "@feathersjs/authentication-local": "5.0.42",
    "@feathersjs/errors": "^5.0.37",
    "@feathersjs/mongodb": "5.0.42",
    "@feathersjs/schema": "^5.0.37",
    "@pinia/nuxt": "^0.11.0",
    "@quasar/extras": "^1.17.0",
    "@unocss/nuxt": "^66.5.4",
    "mongodb": "^6.20.0",
    "nuxt": "^4.4.2",
    "nuxt-feathers-zod": "6.5.29",
    "nuxt-quasar-ui": "^2.1.0",
    "pinia": "3.0.4",
    "quasar": "^2.18.5",
    "vue": "^3.5.33",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^6.2.0",
    "@types/node": "^25.0.0",
    "eslint": "^9.39.2",
    "typescript": "^5.9.3",
    "vue-tsc": "^3.1.8"
  },
  "overrides": {
    "pinia": "3.0.4",
    "vue": "^3.5.33"
  },
  "trustedDependencies": [
    "@parcel/watcher",
    "esbuild",
    "vue-demi"
