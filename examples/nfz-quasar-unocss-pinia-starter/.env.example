# MongoDB local pour le starter NFZ
MONGODB_PORT=27037
MONGO_INITDB_ROOT_USERNAME=root
MONGO_INITDB_ROOT_PASSWORD=changeMe
MONGO_INITDB_DATABASE=nfz_starter
MONGODB_URL=mongodb://root:changeMe@127.0.0.1:27037/nfz_starter?authSource=admin

# Compte de démonstration seedé hors production par défaut.
# En production, définir NFZ_DEMO_ENABLED=true et un mot de passe robuste pour l’activer explicitement.
NFZ_DEMO_ENABLED=true
NFZ_DEMO_USER=admin
NFZ_DEMO_PASSWORD=admin123
NFZ_DEMO_ROLES=admin,user

# Change en production
NUXT_SESSION_PASSWORD=replace-this-with-a-long-random-secret-minimum-32-chars
