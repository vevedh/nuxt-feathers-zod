{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022"],
    "types": ["node"],
    "resolveJsonModule": true,
    "noEmit": true,
    "skipLibCheck": true,
    "strict": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.mts",
    "bin/**/*",
    "scripts/**/*.ts",
    "services/**/*.ts",
    "types/**/*.d.ts",
    "playground/nuxt.config.ts",
    "nuxt.config.ts"
  ],
  "exclude": [
    "dist",
    "node_modules",
    ".nuxt",
    "playground/.nuxt"
  ]
}
