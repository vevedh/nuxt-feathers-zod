{
  "compilerOptions": {
    "target": "ES2022",
    "lib": [
      "ES2022",
      "DOM"
    ],
    "baseUrl": ".",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "paths": {
      "nuxt-feathers-zod/client": [
        "src/runtime/client.ts"
      ],
      "nuxt-feathers-zod/query": [
        "src/runtime/zod/query.ts"
      ],
      "nuxt-feathers-zod/server": [
        "src/runtime/server.ts"
      ],
      "nuxt-feathers-zod/server-auth": [
        "src/runtime/server/authentication.ts"
      ],
      "nuxt-feathers-zod/validators": [
        "src/runtime/zod/validators.ts"
      ]
    },
    "resolveJsonModule": true,
    "types": [
      "node"
    ],
    "strict": true,
    "noEmit": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": [
    "playwright.config.ts",
    "src/**/*.ts",
    "src/**/*.mts",
    "bin/**/*",
    "scripts/**/*.ts",
    "services/**/*.ts",
    "types/**/*.d.ts",
    "playground/nuxt.config.ts",
    "nuxt.config.ts"
  ],
  "exclude": [
    "dist",
    "node_modules",
    ".nuxt",
    "playground/.nuxt"
  ]
}
