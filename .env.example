# Runtime
NODE_ENV=production
NFZ_PORT=3000
NFZ_VERSION=6.4.106
NFZ_MODULE_VERSION=6.4.103
NFZ_IMAGE=nfz-studio

# MongoDB
MONGO_INITDB_ROOT_USERNAME=root
MONGO_INITDB_ROOT_PASSWORD=changeMe
MONGO_PORT=27017
MONGO_URL=mongodb://root:changeMe@mongo:27017/nfz-studio?authSource=admin
NFZ_WITH_MONGO_URL=mongodb://root:changeMe@mongo:27017/nfz-studio?authSource=admin

# Auth runtime
NFZ_AUTH_PROVIDER=local
NFZ_ENABLE_SOCKETIO=false

# Keycloak SSO optional bridge (used only when NFZ_AUTH_PROVIDER=keycloak)
KEYCLOAK_SERVER_URL=
KEYCLOAK_REALM=
KEYCLOAK_CLIENT_ID=
KEYCLOAK_ON_LOAD=check-sso
KEYCLOAK_AUTH_SERVICE_PATH=/_keycloak

# Product / Docker edition
NFZ_PRODUCT_EDITION=community
NFZ_DEVTOOLS_ENABLED=false
NFZ_BUILDER_APPLY_MODE=workspace
NFZ_MONGO_ADMIN_ENABLED=true
NFZ_MONGO_ADMIN_DANGEROUS=false

# Dummy admin seed
NFZ_SEED_DUMMY_USER=true
NFZ_DUMMY_USER_USERNAME=admin
NFZ_DUMMY_USER_EMAIL=admin@example.local
NFZ_DUMMY_USER_PASSWORD=ChangeMe123!
NFZ_DUMMY_USER_ROLES=admin

# License scaffold
NFZ_LICENSE_ENFORCE=false
NFZ_LICENSE_KEY=
NFZ_LICENSE_CUSTOMER=
NFZ_LICENSE_PLAN=starter
NFZ_LICENSE_EXPIRES_AT=
NFZ_LICENSE_FEATURES=builder,diagnostics,mongo-admin,auth-demo,crud-demo
NFZ_LICENSE_GRACE_DAYS=7

# ADCS optional bridge
ADCS_ENABLED=false
ADCS_SCRIPT_PATH=/srv/adcs-request-cli.sh
ADCS_WORK_ROOT=/tmp/adcs
ADCS_BASH_PATH=/bin/bash
ADCS_JOB_TTL_MS=1800000

# Optional local override for edition-aware UI
NFZ_STUDIO_EDITION=

# Workspace seed / reseed controls
NFZ_FORCE_RESEED=false
NFZ_RESEED_ON_VERSION_CHANGE=true
NFZ_BACKUP_WORKSPACE_ON_RESEED=true
